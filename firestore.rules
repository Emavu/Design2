rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedOwner() {
      return isSignedIn() && 
             request.auth.token.email == 'ema.uleckaite@gmail.com' && 
             request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. Validation Blueprints
    function isValidProject(data) {
      return data.keys().hasAll(['id', 'title', 'category', 'imageUrl']) &&
             data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 100 &&
             data.category is string && data.category.size() <= 50 &&
             data.imageUrl is string && data.imageUrl.size() <= 2000 &&
             (!('images' in data) || (data.images is list && data.images.size() <= 10)) &&
             (!('stlUrl' in data) || (data.stlUrl is string && data.stlUrl.size() <= 2000)) &&
             (!('year' in data) || (data.year is string && data.year.size() <= 10)) &&
             (!('description' in data) || (data.description is string && data.description.size() <= 2000));
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['ownerName']) &&
             data.keys().size() == 1 &&
             data.ownerName is string && data.ownerName.size() <= 100;
    }

    // 1. The Master Gate Logic
    
    match /settings/portfolio {
      allow read: if true;
      allow write: if isVerifiedOwner() && isValidSettings(incoming());
    }

    match /projects/{projectId} {
      allow read: if true;
      allow create: if isVerifiedOwner() && isValidId(projectId) && isValidProject(incoming());
      allow update: if isVerifiedOwner() && 
                     isValidProject(incoming()) && 
                     incoming().id == existing().id && // Immutable ID
                     incoming().diff(existing()).affectedKeys().hasOnly(['title', 'category', 'imageUrl', 'images', 'stlUrl', 'year', 'description']);
      allow delete: if isVerifiedOwner();
    }
  }
}
